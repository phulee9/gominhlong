# =============================================================================
# PIPELINE CONFIGURATION
# Hướng dẫn: Thêm file excel mới bằng cách thêm entry vào section 'excel_files'
# =============================================================================

# ---- Kết nối hệ thống --------------------------------------------------------
connections:
  minio:
    endpoint: "localhost:9000"
    access_key: "minioadmin"
    secret_key: "minioadmin"
    secure: false
    bucket_raw: "raw-excel"          # Bucket lưu file excel gốc

  postgresql:
    host: "localhost"
    port: 5432
    database: "data_warehouse"
    user: "dev"
    password: "Inda1234"
    schema_staging: "silver"        # Schema cho bảng bronze
    schema_silver: "silver"
    schema_gold: "gold"

# ---- Cấu hình mặc định -------------------------------------------------------
defaults:
  skip_rows_header: 0               # Số dòng bỏ qua trước header
  null_values: ["", "N/A", "NULL", "null", "None", "-"]
  encoding: "utf-8"
  date_format: "%d/%m/%Y"

# =============================================================================
# DANH SÁCH FILE EXCEL CẦN XỬ LÝ
# =============================================================================
excel_files:

# ===========================================================================
  # LUỒNG NẠP THẲNG ĐỐI TÁC (DIM_PARTNER) - KẾT HỢP KHÁCH HÀNG & NHÀ CUNG CẤP
  # ===========================================================================

  # A. PHẦN NẠP DỮ LIỆU KHÁCH HÀNG (Xóa trắng bảng và nạp mới)
  - file_id: "dim_partner_khach_hang"
    description: "Danh mục đối tác - Nhóm Khách hàng"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_khach_hang*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_khach_hang"
    sheets:
      - sheet_index: 0
        header_row: 3
        data_start_row: 4
        target_table: "Dim_Partner"
        transformer_class: "dim_partner"
        truncate_before_load: false   

        field_mapping:
          - source: "Mã khách hàng"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "Tên khách hàng"
            target: "Partner_Name"
            dtype: "text"
          - source: "Địa chỉ"
            target: "Address"
            dtype: "text"
          - source: "Mã số thuế"
            target: "Tax"
            dtype: "varchar(50)"

        metadata_columns:
          - name: "Partner_Group"    # Đặt ở đây để database tự tạo cột tracking cấu trúc
            dtype: "varchar(100)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"

  # B. PHẦN NẠP DỮ LIỆU NHÀ CUNG CẤP (Ghi nối tiếp vào bảng trên)
  - file_id: "dim_partner_nha_cung_cap"
    description: "Danh mục đối tác - Nhóm Nhà cung cấp"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_nha_cung_cap*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_nha_cung_cap"
    sheets:
      - sheet_index: 0
        header_row: 3
        data_start_row: 4
        target_table: "Dim_Partner"
        transformer_class: "dim_partner"
        truncate_before_load: false  # KHÔNG TRUNCATE để giữ lại dữ liệu Khách hàng vừa nạp

        field_mapping:
          - source: "Mã nhà cung cấp"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "Tên nhà cung cấp"
            target: "Partner_Name"
            dtype: "text"
          - source: "Địa chỉ"
            target: "Address"
            dtype: "text"
          - source: "Mã số thuế"
            target: "Tax"
            dtype: "varchar(50)"

        metadata_columns:
          - name: "Partner_Group"
            dtype: "varchar(100)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 5. DANH MỤC TÀI KHOẢN KẾ TOÁN (DIM_ACCOUNT)
  # ---------------------------------------------------------------------------
  - file_id: "dim_account"
    description: "Danh mục hệ thống tài khoản kế toán và số tài khoản ngân hàng định danh"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_he_thong_tai_khoan*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_he_thong_tai_khoan"
    sheets:
      - sheet_index: 0
        header_row: 3
        data_start_row: 4
        target_table: "Dim_Account"
        transformer_class: "dim_account"
        truncate_before_load: true   # Luôn dọn sạch bảng cũ để làm mới danh mục

        field_mapping:
          - source: "Số tài khoản"
            target: "Account_No"
            dtype: "varchar(50)"
          - source: "Tên tài khoản"
            target: "Account_Name"
            dtype: "varchar(500)"

        metadata_columns:
          - name: "Account_BANK"     # Trường tự động xử lý bóc tách bằng Python
            dtype: "varchar(100)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 6. SỐ TÀI KHOẢN NGÂN HÀNG (DIM_ACCOUNTNUMBER)
  # ---------------------------------------------------------------------------
  - file_id: "dim_account_number"
    description: "Danh mục số tài khoản ngân hàng và mã ngân hàng tương ứng"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_tai_khoan_ngan_hang*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_tai_khoan_ngan_hang"
    sheets:
      - sheet_index: 0
        header_row: 3
        data_start_row: 4
        target_table: "Dim_AccountNumber"
        transformer_class: "dim_account_number"
        truncate_before_load: true

        field_mapping:
          - source: "Số tài khoản"
            target: "Account_Bank"
            dtype: "varchar(100)"
          - source: "Tên ngân hàng"
            target: "Bank_Name"
            dtype: "varchar(255)"

        metadata_columns:
          - name: "Bank_Code"        # Cột này sẽ được Python tự động dò tìm (Lookup)
            dtype: "varchar(50)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 7. DANH MỤC NGÂN HÀNG (DIM_BANK)
  # ---------------------------------------------------------------------------
  - file_id: "dim_bank"
    description: "Danh mục các ngân hàng - Lớp Silver"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_ngan_hang*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_ngan_hang"
    sheets:
      - sheet_index: 0
        header_row: 3                   # Bỏ dòng 1-2, tiêu đề nằm ở dòng 3
        data_start_row: 4               # Dữ liệu bắt đầu từ dòng 4
        target_table: "Dim_Bank"
        truncate_before_load: true      # Luôn xóa trắng dọn sạch dữ liệu cũ để làm mới danh mục

        field_mapping:
          - source: "Tên viết tắt"
            target: "Bank_Code"
            dtype: "varchar(50)"
            
          - source: "Tên đầy đủ"
            target: "Bank_Name"
            dtype: "varchar(500)"

        metadata_columns:
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 8. DANH MỤC KHO BÃI (DIM_WAREHOUSE)
  # ---------------------------------------------------------------------------
  - file_id: "dim_warehouse"
    description: "Danh mục kho bãi - Lớp Silver"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_kho*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_kho"
    sheets:
      - sheet_index: 0
        header_row: 3                   # Bỏ dòng 1-2, tiêu đề nằm ở dòng 3 (index 2 trong pandas)
        data_start_row: 4               # Dữ liệu thực tế bắt đầu từ dòng 4
        target_table: "Dim_Warehouse"
        truncate_before_load: true      # Xóa sạch dữ liệu cũ khi nạp lại để đảm bảo danh mục luôn mới nhất

        field_mapping:
          - source: "Mã kho"
            target: "Warehouse_Code"
            dtype: "varchar(100)"
            
          - source: "Tên kho"
            target: "Warehouse_Name"
            dtype: "varchar(255)"

        metadata_columns:
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 9. DANH MỤC SẢN PHẨM (DIM_PRODUCT)
  # ---------------------------------------------------------------------------
  - file_id: "dim_product"
    description: "Danh mục vật tư, sản phẩm, hàng hóa - Lớp Silver"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Danh_sach_hang_hoa_dich_vu*.xlsx"
    minio_prefix: "misa/excel/Danh_sach_hang_hoa_dich_vu"
    sheets:
      - sheet_index: 0
        header_row: 3                   # Bỏ dòng 1-2, tiêu đề ở dòng 3
        data_start_row: 4               # Dữ liệu từ dòng 4
        target_table: "Dim_Product"
        transformer_class: "dim_product"
        truncate_before_load: true      # Xóa sạch bảng cũ để làm mới danh mục

        field_mapping:
          - source: "Mã"
            target: "Product_Code"
            dtype: "varchar(255)"
          - source: "Tên"
            target: "Product_Name"
            dtype: "text"
          - source: "Đơn vị tính chính"
            target: "Unit_of_Measure"   # Dùng gạch dưới thay dấu cách để tránh lỗi cú pháp SQL
            dtype: "varchar(50)"

        metadata_columns:
          - name: "Product_Category"    # Cột nhóm sản phẩm xử lý tự động bằng Python
            dtype: "varchar(100)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ===========================================================================
  # LUỒNG GỘP DANH MỤC CHỈ TIÊU BÁO CÁO TÀI CHÍNH (DIM_REPORTITEM)
  # ===========================================================================

  # PHẦN A. ĐỌC CHỈ TIÊU TỪ BÁO CÁO TÌNH HÌNH TÀI CHÍNH (B01-DN)
  - file_id: "dim_report_item_b01"
    description: "Danh mục chỉ tiêu báo cáo tài chính B01-DN"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/B01*DN*.xlsx"   # Khớp các file B01 DN
    minio_prefix: "misa/excel/b01_bao_cao_tai_chinh"
    sheets:
      - sheet_index: 0
        header_row: 12                  # Bỏ qua dòng 1-11, tiêu đề ở dòng 12
        data_start_row: 13              # Dữ liệu bắt đầu từ dòng 13
        target_table: "Dim_ReportItem"
        transformer_class: "dim_report_item"
        truncate_before_load: true      # Xóa sạch bảng cũ để nạp mới từ đầu

        # Định nghĩa rỗng để Python tự quét cột động dựa vào vị trí A:J và K:L
        field_mapping: []

        metadata_columns:
          - name: "Item_ID"             # Khóa chính: {Report_Type}_{Item_Code}
            dtype: "varchar(100)"
          - name: "Report_Type"         # Phân loại: B01-DN
            dtype: "varchar(50)"
          - name: "Item_Code"           # Mã số chỉ tiêu
            dtype: "varchar(50)"
          - name: "Item_Name"           # Tên chỉ tiêu đầy đủ
            dtype: "varchar(500)"
          - name: "Parent_ID"           # Mã chỉ tiêu cấp cha
            dtype: "varchar(100)"
          - name: "Sort_Index"          # Chỉ số sắp xếp thứ tự
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"

  # PHẦN B. ĐỌC CHỈ TIÊU TỪ BÁO CÁO KẾT QUẢ HOẠT ĐỘNG KINH DOANH (B02-DN)
  - file_id: "dim_report_item_b02"
    description: "Danh mục chỉ tiêu báo cáo tài chính B02-DN"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/B02*DN*.xlsx"   # Khớp các file B02 DN
    minio_prefix: "misa/excel/b02_bao_cao_hoat_dong_kinh_doanh"
    sheets:
      - sheet_index: 0
        header_row: 7                   # Bỏ qua dòng 1-6, tiêu đề ở dòng 7
        data_start_row: 8               # Dữ liệu bắt đầu từ dòng 8
        target_table: "Dim_ReportItem"
        transformer_class: "dim_report_item"
        truncate_before_load: false     # KHÔNG TRUNCATE để giữ lại dữ liệu B01 vừa nạp

        field_mapping: []

        metadata_columns:
          - name: "Item_ID"
            dtype: "varchar(100)"
          - name: "Report_Type"
            dtype: "varchar(50)"
          - name: "Item_Code"
            dtype: "varchar(50)"
          - name: "Item_Name"
            dtype: "varchar(500)"
          - name: "Parent_ID"
            dtype: "varchar(100)"
          - name: "Sort_Index"
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ===========================================================================
  # NHÓM BẢNG FACT (BẢNG SỰ KIỆN PHÁT SINH)
  # ===========================================================================

  # 1. FACT XUẤT KHO / BÁN HÀNG (FACT_INVENTORY_OUTWARD)
  - file_id: "fact_inventory_outward"
    description: "Sổ chi tiết bán hàng - Ghi nhận xuất kho bán hàng"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/So_chi_tiet_ban_hang*.xlsx"
    minio_prefix: "misa/excel/So_chi_tiet_ban_hang"
    sheets:
      - sheet_index: 0
        header_row: 8                   # Bỏ dòng 1-7, tiêu đề nằm ở dòng 8
        data_start_row: 9               # Dữ liệu phát sinh bắt đầu từ dòng 9
        target_table: "Fact_InventoryOutward"
        transformer_class: "fact_inventory_outward"
        
        # Bảng Fact KHÔNG TRUNCATE để dùng cơ chế Delete - Insert (Rollback theo kỳ)
        truncate_before_load: false     
        
        # ĐIỀU KIỆN ROLLBACK (Ví dụ: Xóa sạch dữ liệu tháng 6/2026 trước khi nạp lại file tháng 6)
        # Khi bạn nạp file của tháng khác, hãy sửa lại ngày ở điều kiện này cho khớp.
        delete_condition: "Posting_Date >= '2026-06-01' AND Posting_Date <= '2026-06-30'"

        field_mapping:
          - source: "Ngày hạch toán"
            target: "Posting_Date"
            dtype: "date"
          - source: "Số chứng từ"
            target: "Voucher_No"
            dtype: "varchar(100)"
          - source: "Số hóa đơn"
            target: "Invoice_No"
            dtype: "varchar(100)"
          - source: "Ngày hóa đơn"
            target: "Invoice_Date"
            dtype: "date"
          - source: "Mã kho"
            target: "Warehouse_Code"
            dtype: "varchar(100)"
          - source: "Mã hàng"
            target: "Product_Code"
            dtype: "varchar(255)"
          - source: "Mã khách hàng"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "Loại tiền"
            target: "Currency"
            dtype: "varchar(50)"
          - source: "Tỷ giá"
            target: "Exchange_Rate"
            dtype: "float"
          - source: "Tổng số lượng bán"
            target: "Outward_Quantity"
            dtype: "float"
          - source: "Doanh số bán"
            target: "Outward_Value"
            dtype: "float"

        metadata_columns:
          - name: "ID"                  # Trường STT tự động sinh bằng Python
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 2. FACT NHẬP KHO / MUA HÀNG (FACT_INVENTORY_INWARD)
  # ---------------------------------------------------------------------------
  - file_id: "fact_inventory_inward"
    description: "Sổ chi tiết mua hàng - Ghi nhận nhập kho vật tư hàng hóa"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/So_chi_tiet_mua_hang*.xlsx"
    minio_prefix: "misa/excel/So_chi_tiet_mua_hang"
    sheets:
      - sheet_index: 0
        header_row: 8                   # Bỏ dòng 1-7, tiêu đề ở dòng 8
        data_start_row: 9               # Dữ liệu từ dòng 9
        target_table: "Fact_InventoryInward"
        transformer_class: "fact_inventory_inward"
        
        # KHÔNG TRUNCATE để giữ lịch sử, dùng cơ chế Rollback theo kỳ
        truncate_before_load: false     
        
        # Điều kiện xóa dữ liệu cũ (Rollback) trước khi nạp lại
        # Lưu ý: Cập nhật điều kiện này theo đúng tháng của file bạn định nạp
        delete_condition: "Posting_Date >= '2026-06-01' AND Posting_Date <= '2026-06-30'"

        field_mapping:
          - source: "Ngày hạch toán"
            target: "Posting_Date"
            dtype: "date"
          - source: "Số chứng từ"
            target: "Voucher_No"
            dtype: "varchar(100)"
          - source: "Số hóa đơn"
            target: "Invoice_No"
            dtype: "varchar(100)"
          - source: "Ngày hóa đơn"
            target: "Invoice_Date"
            dtype: "date"
          - source: "Mã kho"
            target: "Warehouse_Code"
            dtype: "varchar(100)"
          - source: "Mã hàng"
            target: "Product_Code"
            dtype: "varchar(255)"
          - source: "Mã nhà cung cấp"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "Loại tiền"
            target: "Currency"
            dtype: "varchar(50)"
          - source: "Tỷ giá"
            target: "Exchange_Rate"
            dtype: "float"
          - source: "Số lượng mua"
            target: "Inward_Quantity"
            dtype: "float"
          - source: "Giá trị mua"       # Lưu ý sửa lỗi chính tả ở đây nếu file báo lỗi "Gía" hay "Giá"
            target: "Inward_Value"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "ID"                  # STT sinh tự động
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 3. FACT TỒN KHO (FACT_INVENTORY_BALANCE)
  # ---------------------------------------------------------------------------
  - file_id: "fact_inventory_balance"
    description: "Tổng hợp tồn kho - Ghi nhận chốt số lượng/giá trị tồn cuối kỳ"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Tong_hop_ton_kho*.xlsx"
    minio_prefix: "misa/excel/Tong_hop_ton_kho"
    sheets:
      - sheet_index: 0
        header_row: [8, 9]              # Khai báo mảng để gộp dòng tiêu đề 8 và 9
        data_start_row: 10              # Dữ liệu chạy từ dòng 10
        target_table: "Fact_Inventory_Balance"
        transformer_class: "fact_inventory_balance"
        truncate_before_load: false     # Không xóa lịch sử để tracking tồn kho qua các tháng
        
        # Điều kiện Rollback (Xóa đúng dữ liệu của kỳ lấy báo cáo trước khi nạp đè)
        delete_condition: "Snapshot_Date = '2026-05-09'" 

        field_mapping:
          - source: "Mã kho"
            target: "Warehouse_Code"
            dtype: "varchar(100)"
          - source: "Mã hàng"
            target: "Product_Code"
            dtype: "varchar(255)"
          - source: "Cuối kỳ_Số lượng"
            target: "Ending_Quantity"
            dtype: "float"                  # Nên dùng float thay vì int vì MISA có số thập phân
          - source: "Cuối kỳ_Giá trị"
            target: "Ending_Value"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "Snapshot_Date"           # Cột này sẽ được Python dùng Regex tự bắt
            dtype: "date"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 4. FACT DÒNG TIỀN VÀ SỔ TÀI KHOẢN (FACT_CASHFLOW)
  # ---------------------------------------------------------------------------
  - file_id: "fact_cashflow"
    description: "Sổ chi tiết các tài khoản - Theo dõi dòng tiền và công nợ"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/So_chi_tiet_cac_tai_khoan*.xlsx"
    minio_prefix: "misa/excel/So_chi_tiet_cac_tai_khoan"
    sheets:
      - sheet_index: 0
        header_row: 8                   # Bỏ dòng 1-7, tiêu đề ở dòng 8
        data_start_row: 9               # Dữ liệu/Dòng gom nhóm bắt đầu từ dòng 9
        target_table: "Fact_CashFlow"
        transformer_class: "fact_cashflow"
        truncate_before_load: false     # Giữ lịch sử
        
        # Điều kiện Rollback theo kỳ báo cáo
        delete_condition: "Posting_Date >= '2026-04-01' AND Posting_Date <= '2026-04-30'"

        field_mapping:
          - source: "Ngày hạch toán"
            target: "Posting_Date"
            dtype: "date"
          - source: "Ngày chứng từ"
            target: "Voucher_Date"
            dtype: "date"
          - source: "Số chứng từ"
            target: "Voucher_No"
            dtype: "varchar(100)"
          - source: "Diễn giải chung"
            target: "Description"
            dtype: "varchar(500)"
          - source: "TK đối ứng"
            target: "Reciprocal_Account"
            dtype: "varchar(50)"
          - source: "Mã đối tượng"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "Phát sinh Nợ"
            target: "Debit_Amount"
            dtype: "numeric(18,2)"
          - source: "Phát sinh Có"
            target: "Credit_Amount"
            dtype: "numeric(18,2)"
          - source: "Dư Nợ"
            target: "Debit_Balance"
            dtype: "numeric(18,2)"
          - source: "Dư Có"
            target: "Credit_Balance"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "Account_No"          # Sinh tự động bằng hàm Forward-Fill
            dtype: "varchar(50)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 5. FACT KẾT QUẢ KINH DOANH (FACT_INCOME_STATEMENT)
  # ---------------------------------------------------------------------------
  - file_id: "fact_income_statement"
    description: "Báo cáo kết quả hoạt động kinh doanh (B02-DN) - Số liệu phát sinh"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/B02*DN*.xlsx"
    minio_prefix: "misa/excel/b02_bao_cao_hoat_dong_kinh_doanh"
    sheets:
      - sheet_index: 0
        header_row: 7                   # Bỏ dòng 1-6, tiêu đề nằm ở dòng 7
        data_start_row: 8               # Dữ liệu bắt đầu từ dòng 8
        target_table: "Fact_IncomeStatement"
        transformer_class: "fact_income_statement"
        truncate_before_load: false     # Giữ lịch sử các tháng
        
        # Điều kiện Rollback theo tháng (Dựa vào cột Month)
        delete_condition: "Month >= '2026-06-01' AND Month <= '2026-06-30'"

        field_mapping:
          - source: "Mã số"
            target: "Indicator_Code"
            dtype: "varchar(100)"
          - source: "Chỉ tiêu"
            target: "Indicator_Name"
            dtype: "varchar(500)"
          - source: "Kỳ này"
            target: "Current_Period_Amount"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "Month"               # Lấy tự động bằng Regex từ tiêu đề
            dtype: "date"
          - name: "YTD_Amount"          # Giá trị lũy kế từ đầu năm
            dtype: "numeric(18,2)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"

  # ---------------------------------------------------------------------------
  # 6. FACT KẾ HOẠCH KINH DOANH (FACT_BUSINESS_PLAN)
  # ---------------------------------------------------------------------------
  - file_id: "fact_business_plan"
    description: "Kế hoạch kinh doanh nội bộ (KQKD_pa1) - Dữ liệu Target/KPI"
    type: "single_table"
    source_pattern: "raw/mailan/Ke_hoach_kinh_doanh_minh_long_2026.xlsx"
    minio_prefix: "misa/excel/Ke_hoach_kinh_doanh_minh_long_2026"
    sheets:
      - sheet_name: "KQKD_pa1"          # Gọi đích danh tên Sheet chứa dữ liệu
        header_row: 5                   # Bỏ dòng 1-4, tiêu đề nằm ở dòng 5 (dòng chứa chữ T1...T12)
        data_start_row: 6               # Dữ liệu chạy từ dòng 6
        target_table: "Fact_BusinessPlan"
        transformer_class: "fact_business_plan"
        truncate_before_load: true      # Truncate để mỗi lần có file Plan mới thì nạp đè hoàn toàn
        
        # Bỏ trống field_mapping để Python tự do Melt (Unpivot) tất cả các cột T1->T12
        field_mapping: []

        metadata_columns:
          - name: "Indicator_Code"
            dtype: "varchar(100)"
          - name: "Month"
            dtype: "date"
          - name: "Target_Amount"
            dtype: "numeric(18,2)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 7. FACT BÁO CÁO TÌNH HÌNH TÀI CHÍNH (FACT_BALANCE_SHEET)
  # ---------------------------------------------------------------------------
  - file_id: "fact_balance_sheet"
    description: "Báo cáo Tình hình Tài chính (B01-DN) - Số dư đầu kỳ/cuối kỳ"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/B01*DN*.xlsx"
    minio_prefix: "misa/excel/b01_bao_cao_tai_chinh"
    sheets:
      - sheet_index: 0
        header_row: 12                  # Tiêu đề ở dòng 12 (đã trừ 1 thành 11)
        data_start_row: 13              # Dữ liệu từ dòng 13 (đã trừ 1 thành 12)
        target_table: "Fact_BalanceSheet"
        transformer_class: "fact_balance_sheet"
        truncate_before_load: false     # Giữ lịch sử báo cáo
        
        # Xóa dữ liệu kỳ cũ trước khi nạp kỳ mới
        delete_condition: "Reporting_Date = '2026-06-19'" # Ngày chốt báo cáo thực tế trên file

        field_mapping:
          - source: "Mã số"
            target: "Indicator_Code"
            dtype: "varchar(100)"
          - source: "Số cuối kỳ"
            target: "Ending_Balance"
            dtype: "numeric(18,2)"
          - source: "Số đầu kỳ"
            target: "Beginning_Balance"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "Reporting_Date"
            dtype: "date"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 8. FACT TIỀN GỬI TIẾT KIỆM (FACT_TERM_DEPOSIT)
  # ---------------------------------------------------------------------------
  - file_id: "fact_term_deposit"
    description: "Hợp đồng tiền gửi - Theo dõi lãi suất và kỳ hạn"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/mailan/Hop_dong_tien_gui*.xlsm"
    minio_prefix: "misa/mailan/Hop_dong_tien_gui"
    sheets:
      - sheet_index: 0
        header_row: 4                   # Dòng 3 (0-indexed) chính là Row 3 mà script tìm thấy
        data_start_row: 5               # Dữ liệu bắt đầu từ dòng ngay sau đó
        target_table: "Fact_TermDeposit"
        transformer_class: "fact_term_deposit"
        truncate_before_load: false
        
        field_mapping:
          - source: "SỐ SỔ"             # ← bỏ dấu cách cuối
            target: "Passbook_No"
            dtype: "varchar(100)"
          - source: "BANK"
            target: "Bank_Code"
            dtype: "varchar(50)"
          - source: "LS (%)"
            target: "Interest_Rate"
            dtype: "float"
          - source: "KỲ HẠN"
            target: "Term"
            dtype: "integer"
          - source: "TRỊ GIÁ GỐC"      # ← bỏ dấu cách cuối
            target: "Original_Amount"
            dtype: "numeric(18,2)"
          - source: "GIÁ TRỊ CÒN LẠI"
            target: "Remaining_Value"
            dtype: "numeric(18,2)"
          - source: "NGÀY GỬI"
            target: "Deposit_Date"
            dtype: "date"
          - source: "NGÀY ĐÁO"          # ← bỏ dấu cách cuối
            target: "Maturity_Date"
            dtype: "date"
          - source: "NGÀY T/TOÁN"
            target: "Settlement_Date"
            dtype: "date"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
  # 9. FACT CÔNG NỢ PHẢI THU (FACT_ACCOUNTS_RECEIVABLE)
  # ---------------------------------------------------------------------------
  - file_id: "fact_accounts_receivable"
    description: "Chi tiết công nợ phải thu khách hàng"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Chi_tiet_cong_no_phai_thu_khach_hang*.xlsx"
    minio_prefix: "misa/excel/Chi_tiet_cong_no_phai_thu_khach_hang"
    sheets:
      - sheet_index: 0
        header_row: [8, 9]      # ← đổi từ 7 thành [8, 9] (Row 7+8 theo 1-indexed)
        data_start_row: 10
        target_table: "Fact_AccountsReceivable"
        transformer_class: "fact_accounts_receivable"
        truncate_before_load: true

        field_mapping:
          - source: "Ngày hạch toán"
            target: "Posting_Date"
            dtype: "date"
          - source: "Số chứng từ"
            target: "Voucher_No"
            dtype: "varchar(100)"
          - source: "Số hóa đơn"
            target: "Invoice_No"
            dtype: "varchar(100)"
          - source: "Ngày hóa đơn"
            target: "Invoice_Date"
            dtype: "date"
          - source: "Diễn giải"
            target: "Description"
            dtype: "varchar(500)"
          - source: "Mã khách hàng"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "TK đối ứng"
            target: "Reciprocal_Account"
            dtype: "varchar(50)"
          - source: "Phát sinh Nợ_Số tiền"    # ← N hoa
            target: "Debit_Amount"
            dtype: "numeric(18,2)"
          - source: "Phát sinh Có_Số tiền"    # ← Có hoa
            target: "Credit_Amount"
            dtype: "numeric(18,2)"
          - source: "Dư Nợ_Số tiền"           # ← N hoa
            target: "Ending_Debit_Balance"
            dtype: "numeric(18,2)"
          - source: "Dư Có_Số tiền"           # ← Có hoa
            target: "Ending_Credit_Balance"
            dtype: "numeric(18,2)"
          - source: "Loại tiền"
            target: "Currency"
            dtype: "varchar(10)"
          - source: "Tỷ giá"
            target: "Exchange_Rate"
            dtype: "numeric(18,4)"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
# 10. FACT CÔNG NỢ PHẢI TRẢ (FACT_ACCOUNTS_PAYABLE)
# ---------------------------------------------------------------------------
  - file_id: "fact_accounts_payable"
    description: "Chi tiết công nợ phải trả nhà cung cấp"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/misa/Chi_tiet_cong_no_phai_tra_nha_cung_cap*.xlsx"
    minio_prefix: "misa/excel/Chi_tiet_cong_no_phai_tra_nha_cung_cap"
    sheets:
      - sheet_index: 0
        header_row: [8, 9]        # Row 7+8 (1-indexed) → multi-header giống file phải thu
        data_start_row: 10
        target_table: "Fact_AccountsPayable"
        transformer_class: "fact_accounts_payable"
        truncate_before_load: false

        field_mapping:
          - source: "Mã nhà cung cấp"
            target: "Partner_Code"
            dtype: "varchar(100)"
          - source: "Ngày hạch toán"
            target: "Posting_Date"
            dtype: "date"
          - source: "Số chứng từ"
            target: "Voucher_No"
            dtype: "varchar(100)"
          - source: "Số hóa đơn"
            target: "Invoice_No"
            dtype: "varchar(100)"
          - source: "Ngày hóa đơn"
            target: "Invoice_Date"
            dtype: "date"
          - source: "Diễn giải"
            target: "Description"
            dtype: "varchar(500)"
          - source: "TK đối ứng"
            target: "Reciprocal_Account"
            dtype: "varchar(50)"
          - source: "Loại tiền"
            target: "Currency"
            dtype: "varchar(10)"
          - source: "Tỷ giá"
            target: "Exchange_Rate"
            dtype: "numeric(18,4)"
          - source: "Phát sinh Nợ_Số tiền"   # N hoa — flatten từ multi-header
            target: "Debit_Amount"
            dtype: "numeric(18,2)"
          - source: "Phát sinh Có_Số tiền"   # Có hoa
            target: "Credit_Amount"
            dtype: "numeric(18,2)"
          - source: "Dư Nợ_Số tiền"          # N hoa
            target: "Ending_Debit_Balance"
            dtype: "numeric(18,2)"
          - source: "Dư Có_Số tiền"          # Có hoa
            target: "Ending_Credit_Balance"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
# 11. FACT HẠN MỨC TÍN DỤNG (FACT_CREDIT_LIMIT_SUMMARY) 
# ---------------------------------------------------------------------------
  - file_id: "fact_credit_limit_summary"
    description: "Tổng hợp hạn mức tín dụng ngân hàng"
    type: "multi_table"
    source_pattern: "excel-pipeline/raw/mailan/*bc_tin_dung*.xlsx"
    minio_prefix: "noibo/mailan/bc_tin_dung"
    sheets:
      - sheet_name: "Theo dõi vay NH"
        header_row: 1
        data_start_row: 2
        target_table: "Fact_CreditLimitSummary"
        transformer_class: "fact_credit_limit_summary"
        truncate_before_load: true

        field_mapping:
          - source: "NH"
            target: "Bank_Code"
            dtype: "varchar(50)"
          - source: "Tổng HMTD"
            target: "Granted_Limit"
            dtype: "numeric(18,2)"
          - source: "Dư nợ gốc"
            target: "Principal_Balance"
            dtype: "numeric(18,2)"
          - source: "Số tiền còn được giải ngân"
            target: "Remaining_Disbursement"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "Credit_Limit"
            dtype: "numeric(18,2)"
          - name: "Limit_Type"
            dtype: "varchar(50)"
          - name: "Interest_Rate"
            dtype: "float"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
  # ---------------------------------------------------------------------------
# 12. FACT CHI TIẾT KHOẢN VAY (FACT_LOAN)
# ---------------------------------------------------------------------------
  - file_id: "fact_loan"
    description: "Chi tiết các khoản vay ngân hàng"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/mailan/*bc_tin_dung*.xlsx"
    minio_prefix: "noibo/mailan/bc_tin_dung"
    sheets:
      - sheet_name: "Theo dõi vay NH"
        header_row: 12        # Row 12 là header thật (1-indexed)
        data_start_row: 13
        target_table: "Fact_Loan"
        transformer_class: "fact_loan"
        truncate_before_load: true

        field_mapping:
          - source: "NH"
            target: "Bank_Code"
            dtype: "varchar(50)"
          - source: "Nhập Số khế ước"
            target: "Contract_No"
            dtype: "varchar(100)"
          - source: "Nhập Số tiền vay gốc"
            target: "Total_Credit_Limit"
            dtype: "numeric(18,2)"
          - source: "Dư nợ gốc còn lại"
            target: "Remaining_Principal"
            dtype: "numeric(18,2)"
          - source: "Lãi suất vay ban đầu"
            target: "Interest_Rate"
            dtype: "float"
          - source: "Ngày giải ngân"
            target: "Disbursement_Date"
            dtype: "date"
          - source: "Ngày đáo hạn"
            target: "Maturity_Date"
            dtype: "date"
          - source: "Số tiền trả gốc"
            target: "Principal_Payment_Amount"
            dtype: "numeric(18,2)"

        metadata_columns:
          - name: "ID"
            dtype: "integer"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"
    # ---------------------------------------------------------------------------
# # ---------------------------------------------------------------------------
 # 13. FACT TÀI SẢN ĐẢM BẢO (FACT_COLLATERAL)
  # ---------------------------------------------------------------------------
  - file_id: "fact_collateral"
    description: "Tài sản thế chấp tại các ngân hàng"
    type: "single_table"
    source_pattern: "excel-pipeline/raw/mailan/*bc_tin_dung*.xlsx" # Đảm bảo file trong raw/mailan khớp pattern này
    minio_prefix: "noibo/mailan/bc_tin_dung"
    sheets:
      - sheet_name: "TSBĐ Bank"
        header_row: 2
        data_start_row: 3
        target_table: "Fact_Collateral"
        transformer_class: "fact_collateral"
        truncate_before_load: true
        field_mapping:
          - source: "Loại TS"
            target: "Collateral_Type"
            dtype: "varchar(50)"
          - source: "Giá trị thẩm định (VNĐ)"
            target: "Appraised_Value"
            dtype: "numeric(18,2)"
          - source: "Hệ số\n TSBĐ"
            target: "Collateral_Coefficient"
            dtype: "varchar(20)"
          - source: "Giá trị cho vay (VNĐ)"
            target: "Loan_Value"
            dtype: "numeric(18,2)"
          - source: "Số tiền được vay"
            target: "Max_Loan_Amount"
            dtype: "numeric(18,2)"
            
        metadata_columns:
          - name: "Row_ID"
            dtype: "integer"
          - name: "Bank_Code"
            dtype: "varchar(50)"
          - name: "_source_file"
            dtype: "varchar(500)"
          - name: "_loaded_at"
            dtype: "timestamp"
          - name: "_batch_id"
            dtype: "varchar(100)"